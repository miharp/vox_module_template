# frozen_string_literal: true

require 'spec_helper'

RSpec.describe '{{ module_name }}' do
  on_supported_os.each do |os, os_facts|
    context "on #{os}" do
      let(:facts) { os_facts }

      it { is_expected.to compile.with_all_deps }

      it { is_expected.to contain_class('{{ module_name }}::install') }
      it { is_expected.to contain_class('{{ module_name }}::config') }
      it { is_expected.to contain_class('{{ module_name }}::service') }

      it 'install comes before config' do
        is_expected.to contain_class('{{ module_name }}::install')
          .that_comes_before('Class[{{ module_name }}::config]')
      end

      it 'config notifies service' do
        is_expected.to contain_class('{{ module_name }}::config')
          .that_notifies('Class[{{ module_name }}::service]')
      end

      context 'with manage_package => false' do
        let(:params) { { manage_package: false } }

        it { is_expected.to compile.with_all_deps }
        it { is_expected.not_to contain_package('{{ module_name }}') }
      end

      context 'with manage_service => false' do
        let(:params) { { manage_service: false } }

        it { is_expected.to compile.with_all_deps }
        it { is_expected.not_to contain_service('{{ module_name }}') }
      end
    end
  end
end
